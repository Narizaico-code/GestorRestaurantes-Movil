{
  "info": {
    "name": "GestorRestaurantes - Full API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json", 
    "description": "Colección actualizada. Ajusta baseUrl si tu puerto cambia (Dios te ama)."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "<JWT>", "type": "string" }
  ],
  "item": [
    {
      "name": "Restaurants",
      "item": [
        {
          "name": "Create Restaurant (form-data, file: restaurantPhoto)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "restaurantName", "type": "text", "value": "My Restaurant" },
                { "key": "restaurantAddress", "type": "text", "value": "Street 123" },
                { "key": "restaurantPhone", "type": "text", "value": "123456789" },
                { "key": "restaurantEmail", "type": "text", "value": "test@example.com" },
                { "key": "openingHours", "type": "text", "value": "09:00" },
                { "key": "closingHours", "type": "text", "value": "22:00" },
                { "key": "restaurantPhoto", "type": "file" }
              ]
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/restaurants/create"
          }
        },
        { "name": "Get Restaurants", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/restaurants" } },
        { "name": "Get Restaurant by ID", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/restaurants/:id" } },
        { "name": "Update Restaurant", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{ \"restaurantName\": \"New name\" }", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/gestorRestaurantes/api/v1/restaurants/:id" } },
        { "name": "Delete Restaurant", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/restaurants/:id" } }
      ]
    },
    {
      "name": "Menus",
      "item": [
        {
          "name": "Create Menu (form-data, file: menuPhoto)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "menuName", "type": "text", "value": "PizzaMenu" },
                { "key": "menuDescription", "type": "text", "value": "Delicious" },
                { "key": "menuPrice", "type": "text", "value": "12" },
                { "key": "menuCategory", "type": "text", "value": "PLATO_FUERTE" },
                { "key": "restaurantId", "type": "text", "value": "<restaurantId>" },
                { "key": "menuPhoto", "type": "file" }
              ]
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/menus"
          }
        },
        { "name": "Get Menus", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/menus" } },
        { "name": "Get Menu by ID", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/menus/:id" } },
        { "name": "Update Menu (form-data optional file)", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "formdata", "formdata": [ { "key": "menuName", "type": "text", "value": "Updated" }, { "key": "menuPhoto", "type": "file" } ] }, "url": "{{baseUrl}}/gestorRestaurantes/api/v1/menus/:id" } },
        { "name": "Delete Menu", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/menus/:id" } }
      ]
    },
    {
      "name": "Tables",
      "item": [
        {
          "name": "Create Table (form-data)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "tableName", "type": "text", "value": "Mesa 1" },
                { "key": "tableCapacity", "type": "text", "value": "4" },
                { "key": "restaurantId", "type": "text", "value": "<restaurantId>" }
              ]
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/tables"
          }
        },
        { "name": "Get Tables", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/tables" } },
        { "name": "Get Table by ID", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/tables/:id" } },
        { "name": "Update Table (form-data)", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "formdata", "formdata": [ { "key": "tableName", "type": "text", "value": "Mesa X" }, { "key": "tableCapacity", "type": "text", "value": "2" } ] }, "url": "{{baseUrl}}/gestorRestaurantes/api/v1/tables/:id" } },
        { "name": "Delete Table", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/tables/:id" } }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Create Reservation (form-data, optional file: photo)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "restaurantId", "type": "text", "value": "<restaurantId>" },
                { "key": "tableId[]", "type": "text", "value": "<tableId>" },
                { "key": "numberPeople", "type": "text", "value": "4" },
                { "key": "typeReservation", "type": "text", "value": "PERSONAL" },
                { "key": "startDate", "type": "text", "value": "2026-02-25T19:00:00Z" },
                { "key": "endDate", "type": "text", "value": "2026-02-25T21:00:00Z" },
                { "key": "description", "type": "text", "value": "Cena evento" },
                { "key": "photo", "type": "file" }
              ]
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/reservations/create"
          }
        },
        { "name": "Get My Reservations", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/reservations/my-reservations" } },
        { "name": "Update Reservation Status (admin)", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{ \"status\": \"COMPLETADO\" }", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/gestorRestaurantes/api/v1/reservations/status/:id" } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (delivery)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"<restaurantId>\",\n  \"orderType\": \"A_DOMICILIO\",\n  \"deliveryAddress\": \"Calle 123, Ciudad\",\n  \"items\": [\n    { \"menuId\": \"<menuId1>\", \"quantity\": 2 },\n    { \"menuId\": \"<menuId2>\", \"quantity\": 1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/orders"
          }
        },
        {
          "name": "Create Order (dine-in)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"<restaurantId>\",\n  \"orderType\": \"EN_RESTAURANTE\",\n  \"tableId\": \"<tableId>\",\n  \"items\": [\n    { \"menuId\": \"<menuId1>\", \"quantity\": 1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/orders"
          }
        },
        {
          "name": "Create Order (takeaway)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"<restaurantId>\",\n  \"orderType\": \"PARA_LLEVAR\",\n  \"items\": [\n    { \"menuId\": \"<menuId1>\", \"quantity\": 1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/orders"
          }
        },
        {
          "name": "Get Orders by Restaurant",
          "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/orders/restaurant/:restaurantId" }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"LISTO\"\n}\n// Valores permitidos: EN_PREPARACION, LISTO, ENTREGADO, CANCELADO",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/orders/status/:id"
          }
        }
      ]
    },
    {
      "name": "Promotions",
      "item": [
        {
          "name": "Create Promotion (pending approval)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"<restaurantId>\",\n  \"title\": \"Promo 2x1\",\n  \"description\": \"Detalles de la promo\",\n  \"couponCode\": \"SAVE10\",\n  \"discountPercentage\": 10,\n  \"startDate\": \"2026-03-01\",\n  \"endDate\": \"2026-03-31\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/promotions"
          }
        },
        {
          "name": "Get Active Promotions",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/promotions/active" }
        },
        {
          "name": "Approve Promotion (admin)",
          "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/promotions/approve/:id" }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review (restaurant or menu)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"<restaurantId>\",\n  \"menuId\": null,\n  \"rating\": 5,\n  \"comment\": \"Excelente\",\n  \"userName\": \"Cliente\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/gestorRestaurantes/api/v1/reviews"
          }
        },
        { "name": "Get Reviews by Restaurant", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/reviews/restaurant/:restaurantId" } },
        { "name": "Get Reviews by Menu", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/reviews/menu/:menuId" } }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        { "name": "Admin Overview Statistics", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/statistics/admin/overview" } },
        { "name": "Export Admin Statistics PDF", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/statistics/admin/report/pdf" } },
        { "name": "Export Admin Statistics Excel", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/statistics/admin/report/excel" } },
        { "name": "Restaurant Statistics (admin)", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/statistics/:restaurantId" } }
      ]
    },
    {
      "name": "Events",
      "item": [
        { "name": "Create Event", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{ \"reservationId\": \"<reservationId>\", \"description\": \"Evento\" }", "options": { "raw": { "language": "json" } } }, "url": "{{baseUrl}}/gestorRestaurantes/api/v1/events/" } },
        { "name": "Get Events by Reservation", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/events/reservation/:reservationId" } },
        { "name": "Deactivate Event (ADMIN)", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": "{{baseUrl}}/gestorRestaurantes/api/v1/events/deactivate/:id" } }
      ]
    },

    {
  "name": "Create Inventory",
  "request": {
    "method": "POST",
    "header": [
      { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
      { "key": "Content-Type", "value": "application/json", "type": "text" }
    ],
    "url": {
      "raw": "{{baseUrl}}/gestorRestaurantes/api/v1/inventory",
      "host": ["{{baseUrl}}"],
      "path": ["gestorRestaurantes","api","v1","inventory"]
    },
    "body": {
      "mode": "raw",
      "raw": "{\n  \"menuId\": \"<MENU_ID>\",\n  \"restaurantId\": \"<REST_ID>\",\n  \"quantity\": 10\n}"
    }
  }
},

{
  "name": "Create Order (with stock decrement + invoice)",
  "request": {
    "method": "POST",
    "header": [
      { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
      { "key": "Content-Type", "value": "application/json", "type": "text" }
    ],
    "url": {
      "raw": "{{baseUrl}}/gestorRestaurantes/api/v1/orders",
      "host": ["{{baseUrl}}"],
      "path": ["gestorRestaurantes","api","v1","orders"]
    },
    "body": {
      "mode": "raw",
      "raw": "{\n  \"restaurantId\": \"<REST_ID>\",\n  \"items\": [\n    { \"menuId\": \"<MENU_ID>\", \"quantity\": 2 }\n  ],\n  \"orderType\": \"EN_RESTAURANTE\",\n  \"coupon\": \"SAVE10\"   // opcional\n}"
    }
  }
},

{
  "name": "Get Invoice by ID",
  "request": {
    "method": "GET",
    "header": [
      { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
    ],
    "url": {
      "raw": "{{baseUrl}}/gestorRestaurantes/api/v1/invoices/{{invoiceId}}",
      "host": ["{{baseUrl}}"],
      "path": ["gestorRestaurantes","api","v1","invoices","{{invoiceId}}"]
    }
  }
},

{
  "name": "Get Issued Invoices",
  "request": {
    "method": "GET",
    "header": [
      { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
    ],
    "url": {
      "raw": "{{baseUrl}}/gestorRestaurantes/api/v1/invoices/issued",
      "host": ["{{baseUrl}}"],
      "path": ["gestorRestaurantes","api","v1","invoices","issued"]
    }
  }
},

{
  "name": "Get Invoices by Restaurant",
  "request": {
    "method": "GET",
    "header": [
      { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
    ],
    "url": {
      "raw": "{{baseUrl}}/gestorRestaurantes/api/v1/invoices/restaurant/:restaurantId",
      "host": ["{{baseUrl}}"],
      "path": ["gestorRestaurantes","api","v1","invoices","restaurant",":restaurantId"]
    }
  }
},

{
  "name": "Export Invoice PDF",
  "request": {
    "method": "GET",
    "header": [
      { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
    ],
    "url": {
      "raw": "{{baseUrl}}/gestorRestaurantes/api/v1/invoices/:id/pdf",
      "host": ["{{baseUrl}}"],
      "path": ["gestorRestaurantes","api","v1","invoices",":id","pdf"]
    }
  }
},

