# ========================================
# CONFIGURACIÓN DE APIs - BACKEND
# Usa la IP LAN de la máquina del backend (no localhost: el dispositivo físico
# no resuelve el localhost del PC). Ajusta la IP según tu red.
# ========================================

# AuthService - Autenticación y Gestión de Usuarios (Puerto 3005)
EXPO_PUBLIC_AUTH_URL=http://192.168.0.18:3005/api/v1

# Gestor de Restaurantes Backend - Restaurantes, Menús, Reservas, Pedidos, etc. (Puerto 3006)
EXPO_PUBLIC_API_URL=http://192.168.0.18:3006/gestorRestaurantes/api/v1

# Health check del Gestor de Restaurantes
EXPO_PUBLIC_API_HEALTH_URL=http://192.168.0.18:3006/health
