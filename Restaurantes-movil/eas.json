{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_URL": "https://authservice-production-f451.up.railway.app/api/v1",
        "EXPO_PUBLIC_API_URL": "https://gestor-restaurantes-backend.vercel.app/gestorRestaurantes/api/v1",
        "EXPO_PUBLIC_API_HEALTH_URL": "https://gestor-restaurantes-backend.vercel.app/health"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_URL": "https://authservice-production-f451.up.railway.app/api/v1",
        "EXPO_PUBLIC_API_URL": "https://gestor-restaurantes-backend.vercel.app/gestorRestaurantes/api/v1",
        "EXPO_PUBLIC_API_HEALTH_URL": "https://gestor-restaurantes-backend.vercel.app/health"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
