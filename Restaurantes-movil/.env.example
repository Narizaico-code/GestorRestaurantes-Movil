# ========================================
# CONFIGURACIÓN DE APIs - BACKEND
# Copia este archivo a `.env` y coloca la IP LAN real de tu backend.
# En dispositivo físico NO uses localhost (el teléfono no resuelve el localhost del PC).
# `.env` está gitignoreado: NUNCA lo subas al repo.
# ========================================

# AuthService - Autenticación y Gestión de Usuarios (Puerto 3005)
EXPO_PUBLIC_AUTH_URL=http://TU_IP_LAN:3005/api/v1

# Gestor de Restaurantes Backend - Restaurantes, Menús, Reservas, Pedidos, etc. (Puerto 3006)
EXPO_PUBLIC_API_URL=http://TU_IP_LAN:3006/gestorRestaurantes/api/v1

# Health check del Gestor de Restaurantes
EXPO_PUBLIC_API_HEALTH_URL=http://TU_IP_LAN:3006/health
